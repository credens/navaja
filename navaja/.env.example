# ============================================================
# NAVAJA — Variables de entorno
# Copiá este archivo a .env.local y completá los valores
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Correr `supabase start` para obtener estos valores locales
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # supabase start → anon key
SUPABASE_SERVICE_ROLE_KEY=              # supabase start → service_role key

# ── MercadoPago ──────────────────────────────────────────────
MP_APP_ID=                              # Tu App ID de MP
MP_CLIENT_SECRET=                       # Tu Client Secret de MP
MP_WEBHOOK_SECRET=                      # Generalo en el dashboard de MP
# Para desarrollo usar credenciales de prueba (sandbox)
# https://www.mercadopago.com.ar/developers/panel

# ── WhatsApp (Meta Cloud API) ────────────────────────────────
WSP_PLATFORM_PHONE_NUMBER_ID=           # ID del número de la plataforma
WSP_PLATFORM_ACCESS_TOKEN=             # Token de larga duración
WSP_WEBHOOK_VERIFY_TOKEN=navaja_wsp_dev # Token de verificación del webhook

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Navaja
